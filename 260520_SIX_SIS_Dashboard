      +"<td style='max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:10.5px;color:#6b6b67'>"+r.iss+"</td>"
      +"<td class='qr'>"+fmtN(r.d)+"</td>"
      +"<td class='qr'>"+fmtN(r.q)+"</td>"
      +"<td>"+pill+"</td>"
      +"<td style='text-align:center'>"+confBadge(r.conf)+"</td></tr>";
  });
  var tb=document.getElementById("tbody-"+id);if(tb)tb.innerHTML=rows;
  var pi=document.getElementById("pinfo-"+id);if(pi)pi.textContent=(s+1)+"-"+Math.min(s+25,tot)+" of "+fmtC(tot);
  var fc=document.getElementById("fcnt-"+id);if(fc)fc.textContent=tot!==src.length?fmtC(tot)+" of "+fmtC(src.length):"";
  var bp=document.getElementById("bprev-"+id);if(bp)bp.disabled=st.pg===0;
  var bn=document.getElementById("bnext-"+id);if(bn)bn.disabled=st.pg>=mp;
}
